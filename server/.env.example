# =========================
# Server Environment Example
# =========================

# App Environment
NODE_ENV=production
PORT=5000

# MongoDB (example format only — DO NOT PUT REAL CREDENTIALS HERE)
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-url>/<db_name>?retryWrites=true&w=majority

# JWT Auth (example only)
JWT_SECRET=<your_jwt_secret>
JWT_EXPIRE=7d

# CORS / Frontend
CLIENT_URL=https://pro-tic-tac-toe.vercel.app